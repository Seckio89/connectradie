# ─────────────────────────────────────────────────────────────────────────────
# E2E verification config — fill this in ONCE, then copy to `.env.e2e`
#
#   cp .env.e2e.example .env.e2e
#   (fill in the blanks)
#   npm run e2e:doctor        ← tells you exactly what's missing / what's next
#
# .env.e2e is gitignored. Everything here is TEST-only — never put production
# or live values in this file. The scripts refuse to run if you do.
# ─────────────────────────────────────────────────────────────────────────────

# ── From your TEST Supabase project ──────────────────────────────────────────
# Dashboard → Project Settings → API
E2E_SUPABASE_URL=https://REPLACE_WITH_TEST_REF.supabase.co
E2E_SUPABASE_ANON_KEY=
E2E_SUPABASE_SERVICE_KEY=

# Usually just the URL with .functions. in it:
#   https://<test-ref>.functions.supabase.co
E2E_FUNCTIONS_BASE=https://REPLACE_WITH_TEST_REF.functions.supabase.co

# ── Stripe TEST mode ─────────────────────────────────────────────────────────
# Dashboard (TEST MODE toggle on) → Developers → API keys
E2E_STRIPE_SECRET_KEY=sk_test_

# ── Test accounts (defaults are fine — created by `npm run e2e:bootstrap`) ───
E2E_CLIENT_EMAIL=e2e-client@test.local
E2E_CLIENT_PASSWORD=e2e-password-123
E2E_TRADIE_EMAIL=e2e-tradie@test.local

# ── Set fresh before each run by `npm run e2e:quote` ─────────────────────────
E2E_QUOTE_ID=

# Assert the exact hot-water figures ($800 labour + $1,600 materials →
# tradie nets $2,305.12). Leave as 1 when using the seeded quote.
E2E_ASSERT_HOTWATER=1
