# Release signing credentials for the Play Store build.
#
# Copy this file to  android/keystore.properties  and fill in real values.
# That file is git-ignored — NEVER commit it or the .jks keystore itself.
# Losing the keystore means you can no longer update the app on Play, so back
# it up somewhere safe (password manager / secure storage).
#
# Create the upload keystore once with:
#   keytool -genkey -v -keystore connectradie-upload.jks \
#     -alias connectradie -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile is resolved relative to the android/app module (or use an absolute
# path). See docs/android-release-checklist.md §2.

storeFile=connectradie-upload.jks
storePassword=CHANGE_ME
keyAlias=connectradie
keyPassword=CHANGE_ME
