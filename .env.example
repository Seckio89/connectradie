# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-url-here
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# Google Maps API (for address autocomplete)
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PRO_PRICE_ID=price_your_monthly_price_id_here
VITE_STRIPE_PRO_ANNUAL_PRICE_ID=price_your_annual_price_id_here

# Sentry Error Tracking
VITE_SENTRY_DSN=your-sentry-dsn-here

# Web Push Notifications (VAPID key for push notifications)
# Generate with: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# Google Calendar Integration (Set in Supabase Edge Functions Settings)
# GOOGLE_CLIENT_ID=your-google-client-id-here
# GOOGLE_CLIENT_SECRET=your-google-client-secret-here
#
# Note: Google Calendar credentials should be set as environment variables
# in your Supabase Edge Functions settings, not in this .env file.
# See CALENDAR_SETUP.md for detailed setup instructions.
